    "@codemirror/view": "^6.0.0",
    "@lezer/common": "^1.0.0",
    "@types/node": "^16.11.6",
    "esbuild": "^0.28.1",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
